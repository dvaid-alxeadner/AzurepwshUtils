{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "datalakename": {
            "value": "datalakeJUN2026",
            "metadata": {
                "description": "Data lake name."
            }
        },
        "accountType": {
            "value": "Standard_LRS"
        },
        "kind": {
            "value": "StorageV2"
        },
        "accessTier": {
            "value": "Hot"
        },
        "defaultOAuth": {
            "value": true
        },
        "allowedCopyScope": {
            "value": "AAD"
        },
        "dnsEndpointType": {
            "value": "Standard"
        },
        "keySource": {
            "value": "Microsoft.Storage"
        },
        "isBlobSoftDeleteEnabled": {
            "value": false
        },
        "isContainerSoftDeleteEnabled": {
            "value": false
        },
        "isShareSoftDeleteEnabled": {
            "value": false
        },
        "privateEndpointName": {
            "value": "PE_DATALAKE",
            "metadata": {
                "description": "Private endpoint name."
            }
        },
        "targetSubResource": {
            "value": [
                "blob"
            ]
        },
        "subnet": {
            "value": "/subscriptions/<SubscriptionID>/resourceGroups/<ResourceGroupName>/providers/Microsoft.Network/virtualNetworks/<VNETName>/subnets/<Subnet Name>",
            "metadata": {
                "description": "id for the subnet which private endpoint will be connected"
            }
        },
        "environment_tag":
        {
            "value":"TEST",
            "metadata": {
                "description": "Tag to describe the enviroment"
            }
        },
        "oi_tag":
        {
            "value":"10000111",
            "metadata": {
                "description": "Tag for budget classification"
            }
        }
    }
}
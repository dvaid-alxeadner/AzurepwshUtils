{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "adminUsername": {
            "value": null,
            "metadata": {
                "description": "Admin User name"
            }
        },
        "adminPassword": {
            "value": null,
            "metadata": {
                "description": "Admin Password"
            }
        },
        "sshPublicKey": {
            "value": null,
            "metadata": {
                "description": "Public SSH Key for autentication"
            }
        },
        "virtualNetworkId": {
            "value":"/subscriptions/<SubscriptionID>/resourceGroups/<ResourceGroupName>/providers/Microsoft.Network/virtualNetworks/<VNETName>/subnets/<Subnet Name>",
            "metadata": {
                "description": "id of the Vnet"
            }
        },
        "subnetName": {
            "value": "SBNET_VM",
            "metadata": {
                "description": "Name of the subnet where the network interface will exist"
            }
        },
        "virtualMachineName":{
            "metadata": {
                "description": "Name of the virtual machine"
            }
        },
        "offer":{
            "value": "ubuntu-24_04-lts",
            "metadata": {
                "description": "Offer for the OS image"
            }
        },
        "imageSku":
        {
            "value": "server",
            "metadata": {
                "description": "SKU for the OS image"
            }
        },
        "virtualMachineSize":
        {
            "value": "Standard_B2s",
            "metadata": {
                "description": "Size of the VM"
            }
        },
        "storageAccountType":
        {
            "value": "StandardSSD_LRS",
            "metadata": {
                "description": "Type of storage for VM disks."
            }
        },
        "environment_tag":
        {
            "value":"TEST",
            "metadata": {
                "description": "Tag to describe the enviroment"
            }
        },
        "oi_tag":
        {
            "value":"10000111",
            "metadata": {
                "description": "Tag for budget classification"
            }
        }
    }
}